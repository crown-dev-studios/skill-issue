{
  "name": "@crown-dev-studios/second-opinion",
  "version": "0.1.0",
  "description": "CLI for getting a second opinion on the current Claude Code or Codex conversation.",
  "packageManager": "pnpm@10.30.3",
  "type": "module",
  "bin": {
    "second-opinion": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "SKILL.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm run build",
    "pack:dry-run": "npm_config_cache=.npm-cache npm pack --dry-run --json",
    "verify:package": "pnpm run pack:dry-run",
    "start": "tsx src/index.ts",
    "pretest": "pnpm build",
    "test": "pnpm run typecheck && node --test --test-concurrency=1 test/*.test.mjs",
    "release:preflight": "bash scripts/prepare-release.sh",
    "release:check-version": "bash scripts/check-version.sh",
    "release:bump": "bash scripts/bump-version.sh",
    "release:deploy": "bash scripts/deploy.sh",
    "release:manual": "bash scripts/prepare-release.sh"
  },
  "devDependencies": {
    "typescript": "^5.9.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0"
  }
}
