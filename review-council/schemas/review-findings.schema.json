{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Review Findings Export",
  "type": "object",
  "required": [
    "review_id",
    "run_id",
    "reviewer",
    "target",
    "generated_at",
    "summary",
    "findings"
  ],
  "properties": {
    "review_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "reviewer": {
      "type": "string",
      "enum": [
        "claude",
        "codex",
        "other"
      ]
    },
    "target": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "severity",
          "confidence",
          "category",
          "description",
          "evidence",
          "recommended_fix",
          "files"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "p1",
              "p2",
              "p3"
            ]
          },
          "confidence": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "category": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "evidence": {
            "type": "string"
          },
          "recommended_fix": {
            "type": "string"
          },
          "files": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "path"
              ],
              "properties": {
                "path": {
                  "type": "string"
                },
                "line": {
                  "type": "integer",
                  "minimum": 1
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
