{
  "name": "@crown-dev-studios/review-council",
  "version": "0.2.0",
  "description": "Parallel multi-agent code review orchestration with bundled prompts, schemas, and HTML reporting.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crown-dev-studios/review-council.git"
  },
  "homepage": "https://github.com/crown-dev-studios/review-council#readme",
  "bugs": {
    "url": "https://github.com/crown-dev-studios/review-council/issues"
  },
  "packageManager": "pnpm@10.30.3",
  "type": "module",
  "bin": {
    "review-council": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "templates/",
    "schemas/",
    "references/",
    "README.md",
    "SKILL.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "pack:dry-run": "npm_config_cache=.npm-cache npm pack --dry-run --json",
    "review-council:orchestrate": "tsx src/cli.ts",
    "review-council:render": "tsx src/render-review-html.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:unit": "node --import tsx/esm --test test/*.test.ts",
    "test": "pnpm run typecheck && pnpm run test:unit",
    "verify:package": "pnpm run pack:dry-run",
    "release:preflight": "bash scripts/prepare-release.sh",
    "release:check-version": "bash scripts/check-version.sh",
    "release:bump": "bash scripts/bump-version.sh",
    "release:deploy": "bash scripts/deploy.sh",
    "release:manual": "bash scripts/prepare-release.sh"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24",
    "tsx": "^4",
    "typescript": "^5"
  },
  "dependencies": {
    "markdown-it": "^14.1.1"
  }
}
